.env

# Google service-account keys — NEVER commit (this repo is public; a committed SA
# key is a credential leak). Vertex creds live ONLY in the GOOGLE_CREDENTIALS_JSON
# env var (Railway) and are materialized to an OS temp file at runtime — never a
# file in the repo. These patterns are a defensive backstop for local key files.
*service-account*.json
*serviceaccount*.json
*-sa.json
gcp-credentials*.json
google-credentials*.json
application_default_credentials.json
psychic-surf-*.json

.config/
__pycache__/
*.pyc
.pytest_cache/
node_modules/
Ui inspirations/

# Ignore AI IDE Workspace States
.claude/
.gemini/
.cursor/
.antigravity/

# Eval output files (regenerable)
generation_evaluation_results.json
/rag_evaluation_results.json
evals/eval_emotional_loop_results.json
evals/results/_run_log_*.txt

# Local one-off / scratch (often contain hardcoded secrets — keep local)
scripts/fetch_notion_*.py
scripts/fetch_specific_notion_page.py
test_store_node.py
evals/sample_low_confidence_response.py

# Local Claude session backups + offline reference cache
claude_backup/
.offline_reference/

# Frontend test artifacts and stray root lockfile
mindgraph-frontend/test_output.txt
/package-lock.json

# docs/ — keep markdown roadmap/strategy notes versioned, ignore binary assets
docs/Mindgraph.zip
docs/Mindgraph_extracted/
docs/PitchDeck/
docs/screenshots/
docs/Claude Design/
docs/*.pdf
docs/*.jpg
